    "dialogues": [
      {
        "id": "d1_1_1",
        "speaker": "旁白",
        "text": "阳光透过窗帘的缝隙，在木质书桌上洒下金色的光斑。",
        "emotionChange": 2,
        "trigger": null
      },
      {
        "id": "d1_1_2",
        "speaker": "你",
        "text": "这本手账...是多久以前的了？",
        "emotionChange": 1,
        "trigger": null
      },
      {
        "id": "d1_1_3",
        "speaker": "旁白",
        "text": "封面上的樱花图案已经有些褪色，但依然能感受到当年的用心。",
        "emotionChange": 1,
        "trigger": "material_required"
      },
      {
        "id": "d1_1_4",
        "speaker": "内心",
        "text": "那年春天，好像发生了很多事情呢...",
        "emotionChange": 2,
        "trigger": null
      },
      {
        "id": "d1_1_5",
        "speaker": "回忆",
        "text": "「还记得吗？那天黄昏，樱花在夕阳下美得像一场梦。」",
        "emotionChange": 3,
        "trigger": "set_environment",
        "environment": {
          "timeOfDay": "dusk",
          "weather": "clear"
        }
      },
      {
        "id": "d1_1_6",
        "speaker": "旁白",
        "text": "天色渐晚，回忆却愈发清晰...",
        "emotionChange": 2,
        "trigger": null
      },
      {
        "id": "d1_1_7",
        "speaker": "回忆",
        "text": "「到了晚上，我们一起数星星，你说要把最亮的那颗摘下来给我。」",
        "emotionChange": 4,
        "isKeyLine": true,
        "trigger": "set_environment",
        "environment": {
          "timeOfDay": "night",
          "weather": "star"
        }
      }
    ],
    "requiredMaterial": "flower",
    "optionalMaterials": ["cloud", "star"],
    "materialCombos": [
      {
        "id": "combo1_spring_sky",
        "name": "春日晴空",
        "materials": ["flower", "cloud"],
        "hiddenDialogue": {
          "id": "hd1_1_1",
          "speaker": "回忆",
          "text": "那天的云也像棉花糖一样，你笑着说，要把整个春天都装进口袋里。",
          "emotionChange": 4,
          "isHidden": true
        },
        "emotionBonus": 5,
        "sceneFeedback": {
          "type": "particle",
          "effect": "petals",
          "backgroundShift": "linear-gradient(135deg, #fef9c3 0%, #fde68a 50%, #e0e7ff 100%)"
